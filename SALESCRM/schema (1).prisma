// =============================================================================
// Sales CRM — Prisma Schema v1.0
// Stack: PostgreSQL + Prisma
// Conventions: camelCase fields, PascalCase models
// Multi-tenant: tenantId on every business table
// OpenClaw-ready: ai_* fields nullable, populated in Phase 2
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserStatus {
  active
  inactive
  invited
  suspended
}

enum UserRole {
  superAdmin    // platform-level, across all tenants
  admin         // tenant-level admin
  salesManager  // manages a team within tenant
  salesRep      // individual contributor
  viewer        // read-only access
}

enum TenantStatus {
  active
  suspended
  trialExpired
  cancelled
}

enum TenantPlan {
  free
  starter
  growth
  enterprise
}

enum LeadSource {
  manual
  webForm
  importCsv
  inboundEmail
  referral
  socialMedia
  coldOutreach
  event
  aiAgent       // Phase 2: OpenClaw sourced
  other
}

enum LeadPriority {
  low
  medium
  high
  urgent
}

enum DealStatus {
  open
  won
  lost
  onHold
}

enum TaskStatus {
  pending
  inProgress
  completed
  cancelled
  overdue
}

enum TaskPriority {
  low
  medium
  high
}

enum TaskType {
  call
  email
  meeting
  followUp
  demo
  proposal
  other
}

enum CommunicationType {
  email
  call
  meeting
  note
  sms
  whatsapp
  other
}

enum CommunicationDirection {
  inbound
  outbound
  internal
}

enum CommunicationSourceType {
  human         // logged by a sales rep
  aiAgent       // Phase 2: logged by OpenClaw agent
  callingAgent  // Phase 2: logged by voice agent
  system        // automated system event
}

enum ProposalStatus {
  draft
  sent
  viewed
  accepted
  rejected
  expired
  revised
}

enum ProductStatus {
  active
  inactive
  archived
}

enum ProductType {
  oneTime
  recurring
  usage
  bundle
}

enum ActivityEntityType {
  lead
  contact
  company
  deal
  task
  proposal
  product
  user
  pipelineStage
}

// =============================================================================
// TENANT (top-level SaaS org unit)
// =============================================================================

model Tenant {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique  // used for subdomain: acme.yourcrm.com
  domain          String?       @unique  // custom domain if on enterprise
  logoUrl         String?
  plan            TenantPlan    @default(free)
  status          TenantStatus  @default(active)
  trialEndsAt     DateTime?
  billingEmail    String?
  timezone        String        @default("Asia/Kolkata")
  currency        String        @default("INR")
  settings        Json?         // tenant-level feature flags and preferences

  // Relations
  users           User[]
  roles           Role[]
  permissions     Permission[]
  userRoles       UserTenantRole[]
  pipelineStages  PipelineStage[]
  leads           Lead[]
  contacts        Contact[]
  companies       Company[]
  deals           Deal[]
  tasks           Task[]
  communications  Communication[]
  products        Product[]
  proposals       Proposal[]
  activities      ActivityLog[]
  stageMigrations StageMigration[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([slug])
  @@index([status])
  @@map("tenants")
}

// =============================================================================
// USER & AUTH
// =============================================================================

model User {
  id              String        @id @default(cuid())
  tenantId        String
  email           String
  passwordHash    String?
  firstName       String
  lastName        String
  avatarUrl       String?
  phone           String?
  status          UserStatus    @default(invited)
  role            UserRole      @default(salesRep)  // base role shortcut
  lastLoginAt     DateTime?
  invitedById     String?
  inviteToken     String?       @unique
  inviteExpiresAt DateTime?
  refreshToken    String?
  resetToken      String?
  resetExpiresAt  DateTime?

  // Relations
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy       User?         @relation("UserInvites", fields: [invitedById], references: [id], onDelete: SetNull)
  invitees        User[]        @relation("UserInvites")
  userRoles       UserTenantRole[]
  assignedLeads   Lead[]        @relation("LeadAssignee")
  createdLeads    Lead[]        @relation("LeadCreator")
  assignedDeals   Deal[]        @relation("DealAssignee")
  createdDeals    Deal[]        @relation("DealCreator")
  assignedTasks   Task[]        @relation("TaskAssignee")
  createdTasks    Task[]        @relation("TaskCreator")
  communications  Communication[]
  proposals       Proposal[]
  activities      ActivityLog[]
  createdContacts Contact[]
  createdCompanies Company[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([status])
  @@map("users")
}

// =============================================================================
// RBAC — Roles, Permissions, UserTenantRole
// =============================================================================

model Role {
  id          String      @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean     @default(false)  // system roles can't be deleted

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles   UserTenantRole[]
  permissions RolePermission[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String      @id @default(cuid())
  tenantId    String
  resource    String      // e.g. "leads", "deals", "reports"
  action      String      // e.g. "create", "read", "update", "delete", "export"
  description String?

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePerms   RolePermission[]

  createdAt   DateTime    @default(now())

  @@unique([tenantId, resource, action])
  @@index([tenantId])
  @@map("permissions")
}

model RolePermission {
  roleId        String
  permissionId  String

  role          Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserTenantRole {
  id          String    @id @default(cuid())
  userId      String
  tenantId    String
  roleId      String
  assignedById String?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt  DateTime  @default(now())

  @@unique([userId, tenantId, roleId])
  @@index([tenantId])
  @@index([userId])
  @@map("user_tenant_roles")
}

// =============================================================================
// PIPELINE STAGES — fully dynamic, per-tenant, with safe migration
// =============================================================================

model PipelineStage {
  id          String      @id @default(cuid())
  tenantId    String
  name        String
  type        String      // "lead" | "deal" — keeps it extensible without enum changes
  position    Int         // serial order, tenant-controlled
  color       String?     // hex color for UI kanban columns
  description String?
  isActive    Boolean     @default(true)
  isDefault   Boolean     @default(false)   // fallback stage for orphaned records
  isArchived  Boolean     @default(false)   // soft-archived after migration, never hard deleted
  isFinal     Boolean     @default(false)   // marks Won/Lost equivalent stages

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads       Lead[]
  deals       Deal[]
  migratedFrom StageMigration[] @relation("MigrationSource")
  migratedTo   StageMigration[] @relation("MigrationTarget")

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([tenantId, name, type])
  @@index([tenantId, type, isActive])
  @@index([tenantId, position])
  @@map("pipeline_stages")
}

// Audit trail for every stage migration event
model StageMigration {
  id              String        @id @default(cuid())
  tenantId        String
  fromStageId     String
  toStageId       String
  stageType       String        // "lead" | "deal"
  migratedCount   Int
  migratedById    String
  reason          String?       // optional note for why migration happened

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromStage       PipelineStage @relation("MigrationSource", fields: [fromStageId], references: [id], onDelete: Restrict)
  toStage         PipelineStage @relation("MigrationTarget", fields: [toStageId], references: [id], onDelete: Restrict)

  migratedAt      DateTime      @default(now())

  @@index([tenantId])
  @@index([fromStageId])
  @@index([toStageId])
  @@map("stage_migrations")
}

// =============================================================================
// COMPANY (B2B org that contacts/leads belong to)
// =============================================================================

model Company {
  id              String      @id @default(cuid())
  tenantId        String
  name            String
  website         String?
  industry        String?
  size            String?     // "1-10", "11-50", "51-200", "201-500", "500+"
  annualRevenue   Decimal?    @db.Decimal(15, 2)
  country         String?
  state           String?
  city            String?
  address         String?
  pincode         String?
  linkedinUrl     String?
  description     String?     @db.Text
  tags            String[]    @default([])
  customFields    Json?       // extensible key-value for tenant-specific fields

  // OpenClaw Phase 2 fields (nullable, unused in Phase 1)
  aiEnrichmentData    Json?
  aiLastEnrichedAt    DateTime?

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User        @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdById     String
  contacts        Contact[]
  leads           Lead[]
  deals           Deal[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([tenantId, name])
  @@map("companies")
}

// =============================================================================
// CONTACT (individual person)
// =============================================================================

model Contact {
  id              String      @id @default(cuid())
  tenantId        String
  companyId       String?
  firstName       String
  lastName        String?
  email           String?
  phone           String?
  whatsapp        String?
  designation     String?
  department      String?
  linkedinUrl     String?
  avatarUrl       String?
  country         String?
  city            String?
  timezone        String?
  tags            String[]    @default([])
  notes           String?     @db.Text
  isActive        Boolean     @default(true)
  customFields    Json?

  // OpenClaw Phase 2 fields
  aiInterestScore     Int?        // 0-100 interest score gathered by agent
  aiGatheredNeeds     Json?       // structured requirements from first-contact agent
  aiLastContactedAt   DateTime?
  aiPreferredChannel  String?     // "email" | "whatsapp" | "call"

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company         Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdBy       User        @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdById     String
  leads           Lead[]
  deals           Deal[]
  tasks           Task[]
  communications  Communication[]
  proposals       Proposal[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([companyId])
  @@map("contacts")
}

// =============================================================================
// LEAD
// =============================================================================

model Lead {
  id              String        @id @default(cuid())
  tenantId        String
  stageId         String
  contactId       String?
  companyId       String?
  assignedToId    String?
  createdById     String

  title           String        // e.g. "Coworking inquiry - Acme Corp"
  description     String?       @db.Text
  source          LeadSource    @default(manual)
  sourceDetail    String?       // e.g. UTM campaign, referrer name
  priority        LeadPriority  @default(medium)
  estimatedValue  Decimal?      @db.Decimal(15, 2)
  currency        String        @default("INR")
  expectedCloseAt DateTime?
  tags            String[]      @default([])
  customFields    Json?
  isConverted     Boolean       @default(false)  // true when lead becomes a Deal
  convertedAt     DateTime?
  convertedToDealId String?

  // OpenClaw Phase 2 fields
  aiAgentId           String?   // which OpenClaw agent owns this lead
  aiLastAction        String?   // last action taken by agent
  aiHandoffAt         DateTime? // when agent handed off to human
  aiHandoffReason     String?
  aiGatheredRequirements Json?  // structured JSON from requirements agent
  aiProposalDraft     Json?     // draft proposal data from proposal builder agent
  aiSentimentScore    Int?      // 0-100 from calling agent transcript
  aiNextBestAction    String?   // deal coaching agent suggestion

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stage           PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)
  contact         Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company         Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignedTo      User?         @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy       User          @relation("LeadCreator", fields: [createdById], references: [id], onDelete: Restrict)
  tasks           Task[]
  communications  Communication[]
  activities      ActivityLog[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([tenantId, stageId])
  @@index([tenantId, assignedToId])
  @@index([tenantId, isConverted])
  @@index([tenantId, createdAt])
  @@map("leads")
}

// =============================================================================
// DEAL (converted lead or directly created opportunity)
// =============================================================================

model Deal {
  id              String      @id @default(cuid())
  tenantId        String
  stageId         String
  contactId       String?
  companyId       String?
  assignedToId    String?
  createdById     String
  sourceLeadId    String?     // if converted from a Lead

  title           String
  description     String?     @db.Text
  value           Decimal     @default(0) @db.Decimal(15, 2)
  currency        String      @default("INR")
  status          DealStatus  @default(open)
  probability     Int         @default(0)   // 0-100 win probability %
  expectedCloseAt DateTime?
  closedAt        DateTime?
  lostReason      String?
  tags            String[]    @default([])
  customFields    Json?

  // OpenClaw Phase 2 fields
  aiAgentId           String?
  aiWinProbability    Int?      // AI-calculated win probability override
  aiNextBestAction    String?
  aiChurnRiskScore    Int?      // 0-100, from churn risk agent
  aiGatheredRequirements Json?
  aiProposalDraft     Json?

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stage           PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)
  contact         Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company         Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignedTo      User?         @relation("DealAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy       User          @relation("DealCreator", fields: [createdById], references: [id], onDelete: Restrict)
  tasks           Task[]
  communications  Communication[]
  proposals       Proposal[]
  dealProducts    DealProduct[]
  activities      ActivityLog[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([tenantId, stageId])
  @@index([tenantId, status])
  @@index([tenantId, assignedToId])
  @@index([tenantId, expectedCloseAt])
  @@map("deals")
}

// =============================================================================
// TASK
// =============================================================================

model Task {
  id              String        @id @default(cuid())
  tenantId        String
  assignedToId    String?
  createdById     String

  // Polymorphic parent — a task belongs to either a Lead or a Deal or a Contact
  leadId          String?
  dealId          String?
  contactId       String?

  title           String
  description     String?       @db.Text
  type            TaskType      @default(followUp)
  status          TaskStatus    @default(pending)
  priority        TaskPriority  @default(medium)
  dueAt           DateTime?
  completedAt     DateTime?
  reminderAt      DateTime?
  reminderSent    Boolean       @default(false)

  // OpenClaw Phase 2 fields
  aiGeneratedById String?       // which agent created this task
  aiContext       Json?         // agent context that triggered this task

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo      User?         @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy       User          @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  lead            Lead?         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  deal            Deal?         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact         Contact?      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([tenantId, assignedToId])
  @@index([tenantId, status])
  @@index([tenantId, dueAt])
  @@index([leadId])
  @@index([dealId])
  @@map("tasks")
}

// =============================================================================
// COMMUNICATION (unified log: emails, calls, meetings, notes, AI interactions)
// =============================================================================

model Communication {
  id              String                    @id @default(cuid())
  tenantId        String
  userId          String                    // who logged it (human or system user)
  contactId       String?
  leadId          String?
  dealId          String?

  type            CommunicationType
  direction       CommunicationDirection    @default(outbound)
  sourceType      CommunicationSourceType   @default(human)
  subject         String?
  body            String?                   @db.Text
  summary         String?                   // AI-generated summary in Phase 2
  occurredAt      DateTime                  @default(now())
  durationSeconds Int?                      // for calls
  outcome         String?                   // "interested", "not interested", "callback", etc.
  attachments     Json?                     // array of {name, url, size}

  // OpenClaw Phase 2 fields
  aiAgentId           String?
  aiTranscriptUrl     String?   // calling agent transcript storage
  aiSentimentScore    Int?      // 0-100
  aiExtractedData     Json?     // structured data extracted from the communication

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  contact         Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead            Lead?         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  deal            Deal?         @relation(fields: [dealId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
  @@index([tenantId, leadId])
  @@index([tenantId, dealId])
  @@index([tenantId, contactId])
  @@index([tenantId, occurredAt])
  @@map("communications")
}

// =============================================================================
// PRODUCT / SERVICE CATALOG
// =============================================================================

model Product {
  id              String        @id @default(cuid())
  tenantId        String
  name            String
  description     String?       @db.Text
  type            ProductType   @default(oneTime)
  status          ProductStatus @default(active)
  sku             String?
  price           Decimal       @default(0) @db.Decimal(15, 2)
  currency        String        @default("INR")
  billingCycle    String?       // "monthly" | "quarterly" | "annual" — for recurring
  taxRate         Decimal?      @db.Decimal(5, 2)
  category        String?
  tags            String[]      @default([])
  imageUrl        String?
  customFields    Json?

  // OpenClaw Phase 2: inventory integration
  inventoryType   String?       // "coworking_space" | "service" | "digital"
  inventoryRefId  String?       // FK to coworking inventory in IA platform (Phase 2)
  checkAvailability Boolean     @default(false) // whether to check real-time availability

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dealProducts    DealProduct[]
  proposalItems   ProposalItem[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@map("products")
}

// Junction: Deal ↔ Product (a deal can have multiple products/services)
model DealProduct {
  id              String    @id @default(cuid())
  dealId          String
  productId       String
  quantity        Int       @default(1)
  unitPrice       Decimal   @db.Decimal(15, 2)
  discount        Decimal   @default(0) @db.Decimal(5, 2)  // percentage
  totalPrice      Decimal   @db.Decimal(15, 2)
  notes           String?

  deal            Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([dealId, productId])
  @@index([dealId])
  @@map("deal_products")
}

// =============================================================================
// PROPOSAL
// =============================================================================

model Proposal {
  id              String          @id @default(cuid())
  tenantId        String
  dealId          String?
  contactId       String?
  createdById     String
  title           String
  status          ProposalStatus  @default(draft)
  version         Int             @default(1)
  parentProposalId String?        // for revised versions
  validUntil      DateTime?
  sentAt          DateTime?
  viewedAt        DateTime?
  respondedAt     DateTime?
  notes           String?         @db.Text
  terms           String?         @db.Text
  subtotal        Decimal         @default(0) @db.Decimal(15, 2)
  discountAmount  Decimal         @default(0) @db.Decimal(15, 2)
  taxAmount       Decimal         @default(0) @db.Decimal(15, 2)
  totalAmount     Decimal         @default(0) @db.Decimal(15, 2)
  currency        String          @default("INR")
  pdfUrl          String?
  publicToken     String?         @unique  // for shareable proposal link

  // OpenClaw Phase 2 fields
  aiGeneratedById     String?     // which agent built this proposal
  aiGenerationContext Json?       // requirements + inventory data used for generation
  aiVersion           Boolean     @default(false)  // true = AI-generated draft

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deal            Deal?           @relation(fields: [dealId], references: [id], onDelete: SetNull)
  contact         Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdBy       User            @relation(fields: [createdById], references: [id], onDelete: Restrict)
  parentProposal  Proposal?       @relation("ProposalRevisions", fields: [parentProposalId], references: [id], onDelete: SetNull)
  revisions       Proposal[]      @relation("ProposalRevisions")
  items           ProposalItem[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@index([tenantId])
  @@index([tenantId, dealId])
  @@index([tenantId, status])
  @@index([publicToken])
  @@map("proposals")
}

model ProposalItem {
  id              String    @id @default(cuid())
  proposalId      String
  productId       String?   // optional — can have custom line items without a product
  name            String    // copied from product or custom
  description     String?
  quantity        Int       @default(1)
  unitPrice       Decimal   @db.Decimal(15, 2)
  discount        Decimal   @default(0) @db.Decimal(5, 2)
  taxRate         Decimal   @default(0) @db.Decimal(5, 2)
  totalPrice      Decimal   @db.Decimal(15, 2)
  position        Int       @default(0)

  proposal        Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  product         Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([proposalId])
  @@map("proposal_items")
}

// =============================================================================
// ACTIVITY LOG (immutable audit trail — never update, never delete)
// =============================================================================

model ActivityLog {
  id              String              @id @default(cuid())
  tenantId        String
  userId          String              // who performed the action
  entityType      ActivityEntityType
  entityId        String              // ID of the record that changed
  action          String              // "created", "updated", "stage_changed", "assigned", etc.
  oldValue        Json?               // snapshot before change
  newValue        Json?               // snapshot after change
  metadata        Json?               // extra context (IP, user agent, etc.)

  // OpenClaw Phase 2
  aiAgentId       String?             // if action was performed by an AI agent

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  lead            Lead?               @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "activity_lead_fk")
  deal            Deal?               @relation(fields: [entityId], references: [id], onDelete: Cascade, map: "activity_deal_fk")

  createdAt       DateTime            @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, userId])
  @@index([tenantId, createdAt])
  @@map("activity_logs")
}
